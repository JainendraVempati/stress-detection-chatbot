# ─────────────────────────────────────────────────────────────────────────────
# Stress Detection Chatbot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── MongoDB Atlas (Cloud Database) ────────────────────────────────────────────
# MongoDB Atlas is REQUIRED for cloud deployment (Render, Railway, Fly.io, etc.)
# Local mongod is NOT supported on cloud platforms.
#
# HOW TO GET YOUR ATLAS CONNECTION STRING:
#   1. Go to https://cloud.mongodb.com/ and sign in (free tier available)
#   2. Create a new project → Build a Database → Choose "FREE" M0 Shared tier
#   3. Select your preferred cloud provider & region → Click "Create"
#   4. Security Quickstart:
#        - Create a database user (username + strong password) → "Create User"
#        - Under "Where would you like to connect from?" → choose
#          "My Local Environment" (for dev) or "0.0.0.0/0" (allow all IPs for Render)
#   5. Click "Connect" on your cluster → "Drivers" → Select "Node.js"
#   6. Copy the connection string — it looks like:
#        mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
#   7. Replace <username> and <password> with your actual credentials
#   8. Append your database name before the "?" like this:
#        mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/stress_detection_db?retryWrites=true&w=majority
#
# RENDER DEPLOYMENT NOTE:
#   Add this MONGO_URI as an environment variable in your Render service dashboard.
#   Go to your service → Environment → Add Environment Variable
#
# ⚠️  Replace the placeholder below with your ACTUAL Atlas connection string:
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/stress_detection_db?retryWrites=true&w=majority&appName=StressDetectionChatbot

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a strong random string (min 32 chars) — never use a simple word.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_key_change_in_production

# ── ML Microservice ───────────────────────────────────────────────────────────
# Local development (both services on same machine):
ML_SERVICE_URL=http://localhost:5000
# Docker Compose (uses container service name):
# ML_SERVICE_URL=http://ml-service:5000
# Render deployment (replace with your actual Render Python service URL):
# ML_SERVICE_URL=https://stress-detection-ml.onrender.com

# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Chain order: Gemini (primary) → NVIDIA (fallback) → offline templates
#
# ① Gemini 2.0 Flash — PRIMARY LLM (free, fast ~1-2s, GPT-4 quality)
#    HOW TO GET YOUR FREE KEY:
#      1. Go to https://aistudio.google.com/app/apikey
#      2. Sign in with Google → Click "Create API key"
#      3. Copy the key (starts with "AIza...") and paste below
#    Leave empty to skip Gemini and use NVIDIA directly.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ② NVIDIA NIM — FALLBACK LLM (Llama 3.1 70B)
#    HOW TO GET A KEY:
#      1. Go to https://build.nvidia.com/
#      2. Sign up and generate an API key (starts with "nvapi-...")
#    Used automatically when Gemini is unavailable or key is missing.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── Email (Gmail SMTP for OTP verification) ───────────────────────────────────
# Use a Gmail App Password — NOT your regular Gmail password.
# How to get App Password:
#   1. Enable 2-Step Verification in Google Account
#   2. Go to: Google Account → Security → 2-Step Verification → App Passwords
#   3. Select "Mail" and your device → copy the 16-character password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM="StressBot <your-email@gmail.com>"
